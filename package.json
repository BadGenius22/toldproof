{
  "name": "toldproof",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--dns-result-order=ipv4first' next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "seal": "tsx --env-file=.env.local scripts/seal-cli.ts",
    "reveal": "tsx --env-file=.env.local scripts/reveal-cli.ts",
    "test:seal-negative": "tsx --env-file=.env.local scripts/test-seal-negative.ts",
    "agents:gen": "tsx --env-file=.env.local scripts/generate-agent-wallets.ts",
    "deploy:v3": "tsx --env-file=.env.local scripts/deploy-v3.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "logo": "node scripts/generate-logo-jpg.mjs"
  },
  "dependencies": {
    "@mysten/dapp-kit-react": "^2.0.3",
    "@mysten/seal": "^1.1.3",
    "@mysten/sui": "^2.16.2",
    "@mysten/walrus": "^1.1.7",
    "@neondatabase/serverless": "^1.1.0",
    "@tanstack/react-query": "^5.100.10",
    "@vercel/analytics": "^2.0.1",
    "@vercel/mcp-adapter": "^0.3.2",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^6.0.182",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "viem": "^2.48.11",
    "x402-mcp": "^0.1.1",
    "x402-next": "^1.2.0",
    "zod": "^4.4.3",
    "zod-v3": "npm:zod@^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jpeg-js": "^0.4.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.6"
  }
