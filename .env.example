# TOLDPROOF environment template.
# Copy to .env.local for dev. NEVER commit .env.local (see CLAUDE.md non-negotiables).

# --- Sui ---
# Recorded after Day 1 testnet deploy of move/prediction_vault.
NEXT_PUBLIC_SUI_NETWORK=testnet
NEXT_PUBLIC_TOLDPROOF_PACKAGE_ID=
NEXT_PUBLIC_PREDICTION_REGISTRY_ID=

# --- Walrus (testnet) ---
NEXT_PUBLIC_WALRUS_SYSTEM_OBJECT=0x6c2547cbbc38025cf3adac45f63cb0a8d12ecf777cdc75a4971612bf97fdf6af

# --- Seal (testnet key servers — 2-of-2 Mysten committee, per sui-dev skill) ---
NEXT_PUBLIC_SEAL_KEY_SERVER_1=0x73d05d62c18d9374e3ea529e8e0ed6161da1a141a94d3f76ae3fe4e99356db75
NEXT_PUBLIC_SEAL_KEY_SERVER_2=0xf5d14a81a982144ae441cd7d64b09027f116a468bd36e7eca494f750591623c8
NEXT_PUBLIC_SEAL_THRESHOLD=2
# Production-grade fault tolerance: swap to 2-of-3 by adding one of —
# Ruby Nodes:    0x6068c0acb197dddbacd4746a9de7f025b2ed5a5b6c1b1ab44dade4426d141da2
# NodeInfra:     0x5466b7df5c15b508678d51496ada8afab0d6f70a01c10613123382b1b8131007
# Studio Mirai:  0x164ac3d2b3b8694b8181c13f671950004765c23f270321a45fdd04d40cccf0f2
# Overclock:     0x9c949e53c36ab7a9c484ed9e8b43267a77d4b8d70e79aa6b39042e3d4c434105

# --- X (Twitter) API v2 — Basic tier ($100/mo). Day 5+. ---
X_CLIENT_ID=
X_CLIENT_SECRET=
X_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=
# Bot account (@toldproof) for verify-reply mention listener
X_BOT_BEARER_TOKEN=
X_BOT_API_KEY=
X_BOT_API_SECRET=
X_BOT_ACCESS_TOKEN=
X_BOT_ACCESS_TOKEN_SECRET=

# --- Postgres (Neon via Vercel Marketplace) — Day 4+. ---
DATABASE_URL=

# --- Reveal watcher cron keypair ---
# Bech32 sui keypair (suiprivkey1...) — the address that calls reveal() and decrypts via Seal.
# Generate with `sui keytool generate ed25519 --json` and store in Vercel encrypted env, never in repo.
REVEAL_BOT_PRIVATE_KEY=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Used by the reveal-watcher cron to authenticate Vercel cron calls
CRON_SECRET=

# --- Observability ---
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=toldproof.xyz
